# ============================================================
#  Variables d'environnement — À configurer sur Netlify
#  (Site Settings → Environment Variables)
#
#  ⚠️  NE PAS mettre ce fichier avec de vraies valeurs
#      dans Git / GitHub. Gardez-le comme modèle uniquement.
# ============================================================

# Token de ton bot Telegram (obtenu via @BotFather)
TELEGRAM_BOT_TOKEN=COLLE_TON_TOKEN_ICI

# Chat ID du destinataire (groupe, canal ou conversation privée)
# Pour le trouver : envoie un message à ton bot, puis ouvre
# https://api.telegram.org/bot<TON_TOKEN>/getUpdates
# et copie la valeur de result[0].message.chat.id
TELEGRAM_CHAT_ID=COLLE_TON_CHAT_ID_ICI
